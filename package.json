{
  "name": "vision-camera-plugin-inatvision",
  "version": "6.0.0-rc.2",
  "description": "VisionCamera Frame Processor Plugin to label images using iNaturalist's Computer Vision",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "source": "./src/index.tsx",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!lib/typescript/example",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "prepare": "bob build",
    "prepack": "bob build",
    "release": "release-it",
    "example": "yarn --cwd example",
    "bootstrap": "yarn example && yarn install && yarn example pods",
    "start": "yarn example start --reset-cache",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": "https://github.com/inaturalist/vision-camera-plugin-inatvision",
  "author": "Johannes Klein <johannes.t.klein@gmail.com> (https://github.com/inaturalist)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/inaturalist/vision-camera-plugin-inatvision/issues"
  },
  "homepage": "https://github.com/inaturalist/vision-camera-plugin-inatvision#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "h3-js": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@react-native/babel-preset": "0.83.9",
    "@react-native/eslint-config": "0.83.9",
    "@react-native/typescript-config": "0.83.9",
    "@release-it/conventional-changelog": "^9.0.2",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native": "0.70.0",
    "csv-parser": "^3.2.0",
    "del-cli": "^5.1.0",
    "download": "^8.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^28.1.1",
    "pod-install": "^0.1.0",
    "prettier": "^3.0.3",
    "react": "19.2.0",
    "react-native": "0.83.9",
    "react-native-builder-bob": "^0.40.17",
    "react-native-monorepo-config": "^0.3.1",
    "react-native-vision-camera": "4.7.3",
    "react-native-worklets-core": "1.6.3",
    "release-it": "^17.10.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.73.0",
    "react-native-vision-camera": ">=4.1.0",
    "react-native-worklets-core": ">=1.3.3"
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
